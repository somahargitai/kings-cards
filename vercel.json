{
  "buildCommand": "npm run build --workspace=client",
  "outputDirectory": "client/dist",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "$BACKEND_URL/api/:path*"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "$BACKEND_URL/socket.io/:path*"
    }
  ]
}
